{
  "name": "water-writing-monorepo",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "web",
    "api"
  ],
  "scripts": {
    "web:dev": "bun --filter water-writing dev",
    "apidev": "bun --filter water-writing-api dev",
    "web:build": "bun --filter water-writing build",
    "api:build": "bun --filter water-writing-api build",
    "lint": "bun --filter '*' lint"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.4"
  }
}
