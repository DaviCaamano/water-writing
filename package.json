{
  "name": "water-writing-monorepo",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "web",
    "api"
  ],
  "scripts": {
    "dev:web": "bun --filter water-writing dev",
    "dev:api": "bun --filter water-writing-api dev",
    "build:web": "bun --filter water-writing build",
    "build:api": "bun --filter water-writing-api build",
    "lint": "bun --filter '*' lint"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.4"
  }
}
